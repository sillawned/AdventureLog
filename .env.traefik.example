# ============================================================================
# AdventureLog Traefik Configuration
# ============================================================================
#
# This file is for use with docker-compose-traefik.yaml
# It extends the main .env configuration with Traefik-specific settings.
#
# Copy this file to .env.traefik and update the values for your deployment.
#
# IMPORTANT:
# - This configuration uses Let's Encrypt for SSL/TLS certificates
# - Ensure your domain is publicly accessible before starting
# - Port 80 and 443 must be accessible from the internet
#
# ============================================================================

# ============================================================================
# 🌍 DOMAIN & SSL CONFIGURATION
# ============================================================================

# Your public domain name (required)
# Examples: example.com, adventurelog.example.com
DOMAIN=example.com

# Email for Let's Encrypt certificate notifications
# This will be used to notify you about certificate expiration and issues
LETSENCRYPT_EMAIL=admin@example.com


# ============================================================================
# 🌐 FRONTEND CONFIGURATION
# ============================================================================

# Backend API URL for the frontend
# When using Traefik with SSL, use the domain with /api path
PUBLIC_SERVER_URL=https://${DOMAIN}/api

# Origin for CORS
ORIGIN=https://${DOMAIN}

# Maximum body size limit
BODY_SIZE_LIMIT=100000

# Frontend version tag
FRONTEND_VERSION=v0.12.0


# ============================================================================
# 🐘 DATABASE CONFIGURATION
# ============================================================================

# Database host (use service name in Docker)
PGHOST=db

# Database name
POSTGRES_DB=adventurelog

# Database user (must match backend configuration)
POSTGRES_USER=adventurelog

# Database password (REQUIRED - use a strong password!)
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=changeme123


# ============================================================================
# 🔒 DJANGO BACKEND CONFIGURATION
# ============================================================================

# Django secret key (REQUIRED - must be unique and secure!)
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=changeme123

# Admin user configuration (only used on first startup)
DJANGO_ADMIN_USERNAME=admin
DJANGO_ADMIN_PASSWORD=changeme123
DJANGO_ADMIN_EMAIL=admin@example.com

# Public URL of the application (used for image URLs)
PUBLIC_URL=https://${DOMAIN}

# Allowed origins for CSRF protection
# Must include your domain for form submissions to work
CSRF_TRUSTED_ORIGINS=https://${DOMAIN}

# Debug mode - MUST be False in production
DEBUG=False

# Frontend URL (used for email links and redirects)
FRONTEND_URL=https://${DOMAIN}

# Backend version tag
BACKEND_VERSION=v0.12.0


# ============================================================================
# ⚙️  OPTIONAL: Email Configuration
# ============================================================================
# Enable email notifications (password resets, etc.)

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_USE_TLS=True
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@example.com


# ============================================================================
# ⚙️  OPTIONAL: Google Maps Integration
# ============================================================================

# GOOGLE_MAPS_API_KEY=your_google_maps_api_key


# ============================================================================
# ⚙️  OPTIONAL: Strava Integration
# ============================================================================

# STRAVA_CLIENT_ID=your_strava_client_id
# STRAVA_CLIENT_SECRET=your_strava_client_secret


# ============================================================================
# ⚙️  OPTIONAL: Analytics (Umami)
# ============================================================================

# PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
# PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id


# ============================================================================
# ⚙️  OPTIONAL: User Registration & Authentication
# ============================================================================

# DISABLE_REGISTRATION=False
# DISABLE_REGISTRATION_MESSAGE=Registration is disabled for this instance.
# SOCIALACCOUNT_ALLOW_SIGNUP=True
# FORCE_SOCIALACCOUNT_LOGIN=False
# ACCOUNT_EMAIL_VERIFICATION=none
