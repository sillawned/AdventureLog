# ============================================================================
# AdventureLog Environment Configuration
# ============================================================================
#
# This file contains all environment variables for the AdventureLog application.
# Copy this file to .env and update the values for your deployment.
#
# IMPORTANT SECURITY NOTES:
# - Never commit .env files to version control
# - Keep SECRET_KEY secure and unique per deployment
# - Use strong passwords (minimum 16 characters recommended)
# - Rotate secrets regularly in production
#
# For detailed configuration information, see:
# https://adventurelog.app/docs/configuration/
#
# ============================================================================

# ============================================================================
# 🌐 FRONTEND CONFIGURATION
# ============================================================================

# Backend API URL - Used by frontend to communicate with the API
# In Docker: use the service name (http://server:8000)
# In production: use your public domain (https://api.yourdomain.com)
PUBLIC_SERVER_URL=http://server:8000

# Origin for CORS - Where the frontend is served from
# Used for development: http://localhost:{FRONTEND_PORT}
ORIGIN=http://localhost:8015

# Maximum body size limit for requests
BODY_SIZE_LIMIT=Infinity

# Frontend port (exposed port on host machine)
FRONTEND_PORT=8015

# Optional: Frontend version tag for production deployments
# FRONTEND_VERSION=v0.12.0


# ============================================================================
# 🐘 DATABASE CONFIGURATION (PostgreSQL with PostGIS)
# ============================================================================

# Database host
# In Docker: use the service name (db)
# In standalone: use localhost or your database hostname
PGHOST=db

# Database name
POSTGRES_DB=adventurelog

# Database user
POSTGRES_USER=adventurelog

# Database password (REQUIRED - change this in production!)
# Security: Use at least 16 random characters
POSTGRES_PASSWORD=changeme123


# ============================================================================
# 🔒 DJANGO BACKEND CONFIGURATION
# ============================================================================

# Django secret key (REQUIRED - must be unique and secure in production)
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=changeme123

# Admin user configuration (only used on first startup)
DJANGO_ADMIN_USERNAME=admin
DJANGO_ADMIN_PASSWORD=admin
DJANGO_ADMIN_EMAIL=admin@example.com

# Public URL of the application (used for image URLs and email generation)
# In Docker: Match the BACKEND_PORT (http://localhost:8016)
# In production: Use your public domain (https://yourdomain.com)
PUBLIC_URL=http://localhost:8016

# Allowed origins for CSRF protection
# In Docker: http://localhost:8016,http://localhost:8015
# In production: https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:8016,http://localhost:8015

# Debug mode - MUST be False in production
# Set to True only for local development
DEBUG=False

# Frontend URL (used for email links and redirects)
# In Docker: http://localhost:8015
# In production: https://yourdomain.com
FRONTEND_URL=http://localhost:8015

# Backend port (exposed port on host machine)
BACKEND_PORT=8016

# Optional: Backend version tag for production deployments
# BACKEND_VERSION=v0.12.0


# ============================================================================
# ⚙️  OPTIONAL: Email Configuration
# ============================================================================
# Enable email notifications (password resets, invitations, etc.)
# Documentation: https://adventurelog.app/docs/configuration/email.html

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_USE_TLS=True
# EMAIL_PORT=587
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com


# ============================================================================
# ⚙️  OPTIONAL: Google Maps Integration
# ============================================================================
# Enable Google Maps for location services
# Documentation: https://adventurelog.app/docs/configuration/google_maps_integration.html

# GOOGLE_MAPS_API_KEY=your_google_maps_api_key


# ============================================================================
# ⚙️  OPTIONAL: Strava Integration
# ============================================================================
# Connect with Strava for activity tracking
# Documentation: https://adventurelog.app/docs/configuration/strava_integration.html

# STRAVA_CLIENT_ID=your_strava_client_id
# STRAVA_CLIENT_SECRET=your_strava_client_secret


# ============================================================================
# ⚙️  OPTIONAL: Analytics (Umami)
# ============================================================================
# Track application usage with Umami
# Documentation: https://adventurelog.app/docs/configuration/analytics.html

# PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
# PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id


# ============================================================================
# ⚙️  OPTIONAL: User Registration & Authentication
# ============================================================================
# Control user registration and login methods

# Disable new user registration (existing users can still log in)
# DISABLE_REGISTRATION=False
# DISABLE_REGISTRATION_MESSAGE=Registration is disabled for this instance.

# Allow social account signup (Google, GitHub, etc.)
# SOCIALACCOUNT_ALLOW_SIGNUP=True

# Force social login only (disable username/password login)
# FORCE_SOCIALACCOUNT_LOGIN=False

# Email verification requirement
# Options: 'none' (no verification), 'optional', 'mandatory'
# ACCOUNT_EMAIL_VERIFICATION=none
